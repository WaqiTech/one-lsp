{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": ["**/*.ts", "**/*.json"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true
	}
}
